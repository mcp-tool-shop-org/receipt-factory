{
  "name": "@mcptoolshop/rf-cli",
  "version": "1.1.0",
  "description": "The rf command — create, render, and verify receipts",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "rf": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mcptoolshop/rf-core": "workspace:*",
    "@mcptoolshop/rf-render": "workspace:*",
    "@mcptoolshop/rf-verify": "workspace:*",
    "@mcptoolshop/rf-adapter-github": "workspace:*",
    "@mcptoolshop/rf-pipeline-ci": "workspace:*",
    "@mcptoolshop/rf-pipeline-release": "workspace:*",
    "@mcptoolshop/rf-sign": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "mcp-tool-shop <64996768+mcp-tool-shop@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/receipt-factory.git",
    "directory": "apps/factory-cli"
  },
